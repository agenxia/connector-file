{
  "name": "File Connector",
  "description": "Read, write, list, and transform files via a simple API with storage support",
  "type": "connector",
  "complexity": "beginner",
  "features": [
    "File read/write",
    "Directory listing",
    "File transformation (JSON, CSV)",
    "In-memory storage",
    "Size limits",
    "MIME type detection"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "MAX_FILE_SIZE"
  ],
  "icon": "📁",
  "connector": {
    "service_name": "file",
    "auth_type": "none",
    "capabilities": [
      "read",
      "write",
      "list",
      "transform"
    ]
  },
  "methods": [
    {
      "name": "read",
      "description": "Read a file from URL or local storage",
      "params": {
        "path": {
          "type": "string",
          "required": true,
          "description": "File path or URL"
        }
      },
      "returns": {
        "content": {
          "type": "string",
          "description": "File content"
        },
        "type": {
          "type": "string",
          "description": "MIME type"
        }
      }
    }
  ],
  "api": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/.well-known/agent-card.json",
      "description": "Agent discovery card"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "API documentation (HTML)"
    },
    {
      "method": "POST",
      "path": "/api/a2a",
      "description": "A2A JSON-RPC 2.0 endpoint"
    }
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": "template-file",
    "type": "connector"
  }
}